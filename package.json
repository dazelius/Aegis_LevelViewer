{
  "name": "aegis-level-viewer",
  "private": true,
  "version": "0.1.0",
  "description": "Web-based viewer for Unity scenes from Project Aegis",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=web",
    "build": "npm run build --workspace=server && npm run build --workspace=web",
    "start": "npm run start --workspace=server",
    "bake": "npm run bake --workspace=server"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
